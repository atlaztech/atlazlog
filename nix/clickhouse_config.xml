<clickhouse>
  <path>/var/lib/clickhouse/</path>
  <tmp_path>/var/lib/clickhouse/tmp</tmp_path>
  <user_files_path>/var/lib/clickhouse/user_files</user_files_path>
  <profiles>
    <default/>
  </profiles>

  <users>
    <default>
      <password>password</password>
    </default>
  </users>

  <listen_host>0.0.0.0</listen_host>
  <http_port>8123</http_port>
  <tcp_port>9000</tcp_port>
  <mysql_port>9004</mysql_port>
  <postgresql_port>9005</postgresql_port>

  <logger>
    <log>/var/log/clickhouse-server/clickhouse.log</log>
    <errorlog>/var/log/clickhouse-server/clickhouse_err.log</errorlog>
    <level>none</level>
    <console>0</console>
  </logger>

  <trace_log>
    <ttl>event_date + INTERVAL 7 DAY</ttl>
  </trace_log>
  <query_log>
    <ttl>event_date + INTERVAL 7 DAY</ttl>
  </query_log>
  <query_thread_log>
    <ttl>event_date + INTERVAL 7 DAY</ttl>
  </query_thread_log>
  <part_log>
    <ttl>event_date + INTERVAL 7 DAY</ttl>
  </part_log>
  <metric_log>
    <ttl>event_date + INTERVAL 7 DAY</ttl>
  </metric_log>

  <compression>
    <case>
      <method>zstd</method>
      <level>5</level>
    </case>
  </compression>
</clickhouse>
